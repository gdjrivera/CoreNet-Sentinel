# ============================================
# FortiGate Backup Notification
# ============================================
# Type: {{ notification_type | default('backup') }}
# Status: {{ notification_status | default('unknown') }}
# Timestamp: {{ ansible_date_time.iso8601 }}
# Generated by: {{ ansible_user_id | default('system') }}
# ============================================

HOST DETAILS:
  Hostname:    {{ fgt_hostname | default(inventory_hostname) }}
  Model:       {{ fgt_model | default('N/A') }}
  Serial:      {{ fgt_serial | default('N/A') }}
  Firmware:    {{ fgt_version | default('N/A') }}
  Role:        {{ fgt_role | default('N/A') }}
  Region:      {{ fgt_region | default('N/A') }}
  Location:    {{ fgt_location | default('N/A') }}

BACKUP DETAILS:
  Method:      {{ backup_method_used | default('N/A') }}
  Timestamp:   {{ backup_timestamp | default('N/A') }}
  Config Size: {{ backup_size | default('N/A') }} bytes
  SHA-256:     {{ backup_hash | default('N/A') }}

MESSAGE:
  {{ notification_message | default('No message provided') }}

BACKUP LOCATION:
  {{ backup_base_dir }}/{{ inventory_hostname }}/{{ ansible_date_time.date }}/
