#!/bin/bash
# ============================================
# Git Push Wrapper for FortiGate Backups
# ============================================
# This script is generated by Ansible and handles
# git operations with proper error handling.
# ============================================

set -euo pipefail

BACKUP_DIR="{{ backup_base_dir }}"
GIT_REPO="{{ git_repo_url }}"
GIT_BRANCH="{{ git_branch }}"
GIT_EMAIL="backup-system@internal.local"
GIT_NAME="FortiGate Backup System"
RETENTION_DAYS="{{ backup_retention_days }}"
TIMESTAMP=$(date -u +"%Y%m%d_%H%M%S")
LOG_FILE="/var/log/fortigate-backup/git-sync-${TIMESTAMP}.log"

log() {
    local level="$1"
    local message="$2"
    echo "[${TIMESTAMP}] [${level}] ${message}" | tee -a "${LOG_FILE}"
}

cleanup() {
    local exit_code=$?
    if [ ${exit_code} -ne 0 ]; then
        log "ERROR" "Git sync failed with exit code ${exit_code}"
    else
        log "INFO" "Git sync completed successfully"
    fi
    exit ${exit_code}
}

trap cleanup EXIT

log "INFO" "Starting git synchronization"
log "INFO" "Backup directory: ${BACKUP_DIR}"
log "INFO" "Repository: ${GIT_REPO}"
log "INFO" "Branch: ${GIT_BRANCH}"

# Validate backup directory exists
if [ ! -d "${BACKUP_DIR}" ]; then
    log "ERROR" "Backup directory ${BACKUP_DIR} does not exist"
    exit 1
fi

cd "${BACKUP_DIR}"

# Configure git
git config user.name "${GIT_NAME}"
git config user.email "${GIT_EMAIL}"

# Initialize if needed
if [ ! -d ".git" ]; then
    log "INFO" "Initializing new git repository"
    git init
    git remote add origin "${GIT_REPO}"
    git checkout -b "${GIT_BRANCH}"
fi

# Verify remote connectivity
if ! git remote -v &>/dev/null; then
    log "ERROR" "No git remote configured"
    exit 1
fi

# Stage all changes
log "INFO" "Staging backup files"
git add -A

# Check for changes
if git diff --cached --quiet; then
    log "INFO" "No changes to commit"
    exit 0
fi

# Count changes
CHANGED_FILES=$(git diff --cached --name-only | wc -l)
log "INFO" "Changes detected in ${CHANGED_FILES} files"

# Commit
log "INFO" "Creating commit"
git commit -m "[backup] Automated backup - $(date -u +'%Y-%m-%d %H:%M:%S UTC')

Devices: $(git diff --cached --name-only | cut -d'/' -f1 | sort -u | tr '\n' ' ')"

# Tag
TAG_NAME="backup-$(date -u +'%Y%m%d-%H%M%S')"
git tag -a "${TAG_NAME}" -m "Automated backup ${TAG_NAME}"

# Push
log "INFO" "Pushing to remote repository"
if git push origin "${GIT_BRANCH}" --tags 2>&1; then
    log "INFO" "Push successful"
else
    log "WARN" "Push failed, attempting pull before retry"
    git pull --rebase origin "${GIT_BRANCH}"
    git push origin "${GIT_BRANCH}" --tags
fi

# Cleanup old local tags beyond retention
log "INFO" "Cleaning up old tags"
git tag -l 'backup-*' | sort -r | tail -n +"${RETENTION_DAYS}" | while read -r tag; do
    git tag -d "${tag}" 2>/dev/null || true
done

log "INFO" "Git synchronization completed"
exit 0
