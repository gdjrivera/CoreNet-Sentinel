# ============================================
# FortiGate Backup System - .gitignore
# ============================================

# ---------- CREDENCIALES (NUNCA subir) ----------
ansible/vault/.vault_password
ansible/vault/.vault_password_*
ansible/vault/*.yml
ansible/vault/*.yaml

# ---------- ENTORNO VIRTUAL ----------
venv/
.venv/
env/
.env
.Python
bin/
lib/
lib64/
include/
pyvenv.cfg
pip-selfcheck.json

# ---------- PYTHON ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------- SSH KEYS (NUNCA subir) ----------
*.pem
*.key
id_*
fortigate-backup-key*
ssh-key-*
authorized_keys
known_hosts

# ---------- CERTIFICADOS ----------
*.p12
*.jks
*.crt
*.cer
*.p7b
*.pfx

# ---------- SECRETOS ----------
*.secret
*.token
credential*
*.env
.env.*
.git-crypt-key*

# ---------- BACKUPS GENERADOS ----------
/opt/backups/
data/
*.tar.gz
*.zip
*.7z
*.rar

# ---------- LOGS ----------
*.log
/var/log/fortigate-backup/

# ---------- REPORTES GENERADOS ----------
reports/
*.html
*.pdf

# ---------- BASES DE DATOS LOCALES ----------
*.db
*.sqlite
*.sqlite3

# ---------- ANSIBLE ----------
*.retry
ansible/inventory/production/hosts.yml.bak
ansible/inventory/staging/hosts.yml.bak

# ---------- GIT-CRYPT ----------
.git-crypt/
*.gpg
*.pub.gpg

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
.vs/

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
*.bak
*.tmp

# ---------- DOCKER ----------
docker-compose.override.yml
data/

# ---------- CI/CD ----------
artifacts/
*.artifact
coverage/
test-results/
junit/
