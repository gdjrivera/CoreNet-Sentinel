# Forzar LF (Unix) para archivos que DEBEN tener LF
*.sh           text eol=lf
*.ps1          text eol=lf
*.py           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.j2           text eol=lf
*.cfg          text eol=lf
*.conf         text eol=lf
Makefile       text eol=lf
Makefile.*     text eol=lf
Dockerfile     text eol=lf
*.service      text eol=lf
*.timer        text eol=lf
*.cron         text eol=lf
*.hook         text eol=lf

# Archivos que pueden quedar como CRLF (Windows)
*.md           text
*.txt          text
*.json         text
*.xml          text
*.html         text
*.css          text
*.js           text

# Binarios (no modificar)
*.png          binary
*.jpg          binary
*.ico          binary
*.gpg          binary
*.p12          binary
*.jks          binary

# Git
.gitignore     text
.gitattributes text
